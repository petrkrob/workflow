{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://financial-advisor-workflow/schemas/meeting-summary.json",
  "title": "MeetingSummary",
  "description": "Structured extraction from a meeting transcript",
  "type": "object",
  "required": ["summary_id", "case_id", "transcript_id", "meeting_context", "discussed_topics", "next_step", "review_status"],
  "properties": {
    "summary_id": { "type": "string" },
    "case_id": { "type": "string" },
    "transcript_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "meeting_context": {
      "type": "object",
      "required": ["participants", "meeting_date"],
      "properties": {
        "participants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string", "enum": ["advisor", "client", "partner", "other"] },
              "notes": { "type": "string" }
            }
          }
        },
        "meeting_type": { "type": "string" },
        "meeting_date": { "type": "string", "format": "date" },
        "duration_minutes": { "type": "number", "minimum": 0 },
        "location": { "type": "string" },
        "general_mood": { "type": "string" }
      }
    },
    "discussed_topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "key_points"],
        "properties": {
          "topic": { "type": "string" },
          "category": { "type": "string", "enum": ["insurance", "investment", "mortgage", "retirement", "savings", "tax", "estate", "general", "other"] },
          "key_points": { "type": "array", "items": { "type": "string" } },
          "source_segments": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "financial_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact", "confidence", "source"],
        "properties": {
          "fact": { "type": "string" },
          "category": { "type": "string" },
          "value": { "type": "string" },
          "confidence": { "type": "string", "enum": ["confirmed", "mentioned", "inferred", "uncertain"] },
          "source": { "type": "string", "enum": ["client_statement", "document", "advisor_observation", "inferred"] }
        }
      }
    },
    "client_goals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "timeframe": { "type": "string", "enum": ["short_term", "medium_term", "long_term"] },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "confidence": { "type": "string", "enum": ["explicit", "inferred"] }
        }
      }
    },
    "client_concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "related_topic": { "type": "string" }
        }
      }
    },
    "current_products_mentioned": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["context"],
        "properties": {
          "product_name": { "type": "string" },
          "provider": { "type": "string" },
          "type": { "type": "string" },
          "context": { "type": "string", "enum": ["existing", "proposed", "discussed", "to_be_reviewed"] },
          "details": { "type": "string" }
        }
      }
    },
    "desired_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "area"],
        "properties": {
          "description": { "type": "string" },
          "area": { "type": "string" },
          "urgency": { "type": "string", "enum": ["immediate", "soon", "future"] },
          "agreed": { "type": "boolean" }
        }
      }
    },
    "agreements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "responsible"],
        "properties": {
          "description": { "type": "string" },
          "responsible": { "type": "string", "enum": ["advisor", "client", "both"] },
          "deadline": { "type": "string" }
        }
      }
    },
    "advisor_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "assigned_to", "priority", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "description": { "type": "string" },
          "assigned_to": { "type": "string", "const": "advisor" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "deadline": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "completed"] }
        }
      }
    },
    "client_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "assigned_to", "priority", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "description": { "type": "string" },
          "assigned_to": { "type": "string", "const": "client" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "deadline": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "completed"] }
        }
      }
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "importance"],
        "properties": {
          "description": { "type": "string" },
          "category": { "type": "string" },
          "importance": { "type": "string", "enum": ["critical", "important", "nice_to_have"] },
          "suggested_question": { "type": "string" }
        }
      }
    },
    "follow_up_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "type", "responsible"],
        "properties": {
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["action", "question", "document_request", "meeting"] },
          "responsible": { "type": "string", "enum": ["advisor", "client"] },
          "deadline": { "type": "string" }
        }
      }
    },
    "next_step": { "type": "string" },
    "review_status": {
      "type": "string",
      "enum": ["pending", "approved", "edited_and_approved", "rejected"]
    },
    "reviewer_notes": { "type": "string" },
    "reviewed_at": { "type": "string", "format": "date-time" }
  }
}
